/*
 * torabo-tsuki LP M キーマップ（Cornix LP 移植版・M 専用）
 *
 * 物理レイアウトを M に固定（dtsi の chosen で設定）。
 * バインディングは M の transform に直接対応する 52 キー (4行 × 14列)。
 *
 *   Line 1 (bindings 0-11)   : Q行          12 keys
 *   Line 2 (bindings 12-23)  : A行          12 keys
 *   Line 3 (bindings 24-37)  : Z行 + 内側親指 14 keys (中央2 = 内側親指)
 *   Line 4 (bindings 38-51)  : 親指row     14 keys (中央2 = 内側親指)
 *
 * 親指配置 (Cornix 互換):
 *   左 thumb cluster : 28(LALT) 29(LGUI) 30(SPACE)  ※ 30 が内側
 *   右 thumb cluster : 31(NO)  32(MO1) 33(MO2)      ※ 31 が内側 (トラックボールで省略)
 *   外側下段は全て NO
 *
 * レイヤー:
 *   0: ベース
 *   1: 数字・記号・矢印 (右親指 MO(1))
 *   2: F1-F12 (右親指 MO(2))
 *   3: アプリ切替マクロ (MO(1)+MO(2) で起動, conditional_layer)
 */

#include <behaviors.dtsi>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/outputs.h>
#include <dt-bindings/zmk/pointing.h>

/ {
    macros {
        m_app0: macro_app0 {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&macro_press &kp LGUI &kp LALT>, <&macro_tap &kp N0>, <&macro_release &kp LALT &kp LGUI>;
        };
        m_app1: macro_app1 {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&macro_press &kp LGUI &kp LALT>, <&macro_tap &kp N1>, <&macro_release &kp LALT &kp LGUI>;
        };
        m_app2: macro_app2 {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&macro_press &kp LGUI &kp LALT>, <&macro_tap &kp N2>, <&macro_release &kp LALT &kp LGUI>;
        };
        m_app3: macro_app3 {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&macro_press &kp LGUI &kp LALT>, <&macro_tap &kp N3>, <&macro_release &kp LALT &kp LGUI>;
        };
        m_app4: macro_app4 {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&macro_press &kp LGUI &kp LALT>, <&macro_tap &kp N4>, <&macro_release &kp LALT &kp LGUI>;
        };
        m_app5: macro_app5 {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&macro_press &kp LGUI &kp LALT>, <&macro_tap &kp N5>, <&macro_release &kp LALT &kp LGUI>;
        };
        m_app6: macro_app6 {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&macro_press &kp LGUI &kp LALT>, <&macro_tap &kp N6>, <&macro_release &kp LALT &kp LGUI>;
        };
    };

    combos {
        compatible = "zmk,combos";

        combo_hash {
            timeout-ms = <50>;
            key-positions = <14 15>;  // S + D
            bindings = <&kp LS(N3)>;
            layers = <0>;
        };
        combo_asterisk {
            timeout-ms = <50>;
            key-positions = <15 16>;  // D + F
            bindings = <&kp LS(N8)>;
            layers = <0>;
        };
        combo_kana {
            timeout-ms = <50>;
            key-positions = <19 20>;  // J + K
            bindings = <&kp LANGUAGE_1>;
            layers = <0>;
        };
        combo_eisu {
            timeout-ms = <50>;
            key-positions = <20 21>;  // K + L
            bindings = <&kp LANGUAGE_2>;
            layers = <0>;
        };
    };

    conditional_layers {
        compatible = "zmk,conditional-layers";
        tri_layer {
            if-layers = <1 2>;
            then-layer = <3>;
        };
    };

    keymap {
        compatible = "zmk,keymap";

        // ========== Layer 0: ベース ==========
        layer_0 {
            bindings = <
// Q行 (0-11): TAB Q W E R T | Y U I O P BSPC
&kp TAB    &kp Q      &kp W      &kp E      &kp R      &kp T                                                      &kp Y      &kp U      &kp I      &kp O      &kp P      &kp BSPC
// A行 (12-23): LCTRL A S D F G | H J K L ; ENTER
&kp LCTRL  &kp A      &kp S      &kp D      &kp F      &kp G                                                      &kp H      &kp J      &kp K      &kp L      &kp SEMI   &kp ENTER
// Z行 (24-37): LSHFT Z X C V B [内親指×2 NO] N M , . / RSHFT
&kp LSHFT  &kp Z      &kp X      &kp C      &kp V      &kp B      &none                      &none              &kp N      &kp M      &kp COMMA  &kp DOT    &kp FSLH   &kp RSHFT
// 親指row (38-51): NO×4 LALT LGUI SPACE [内親指 NO/NO] MO1 MO2 NO×4
&none      &none      &none      &none      &kp LALT   &kp LGUI   &kp SPACE                  &none              &mo 1      &mo 2      &none      &none      &none      &none
            >;
        };

        // ========== Layer 1: 数字・記号・矢印 (MO(1)) ==========
        layer_1 {
            bindings = <
// Q行: ESC 1-5 | 6-0 trans
&kp ESC    &kp N1     &kp N2     &kp N3     &kp N4     &kp N5                                                     &kp N6     &kp N7     &kp N8     &kp N9     &kp N0     &trans
// A行: trans ' - ` = LS(\) | LEFT DOWN UP RIGHT \ trans
&trans     &kp SQT    &kp MINUS  &kp GRAVE  &kp EQUAL  &kp LS(BSLH)                                               &kp LEFT   &kp DOWN   &kp UP     &kp RIGHT  &kp BSLH   &trans
// Z行: trans [ ] none none - [trans×2] HOME END DEL trans trans trans
&trans     &kp LBKT   &kp RBKT   &none      &none      &kp MINUS  &trans                     &trans             &kp HOME   &kp END    &kp DEL    &trans     &trans     &trans
// 親指row: trans
&none      &none      &none      &none      &trans     &trans     &trans                     &trans             &trans     &trans     &none      &none      &none      &none
            >;
        };

        // ========== Layer 2: F1-F12 (MO(2)) ==========
        layer_2 {
            bindings = <
// Q行: trans F1-F5 | F6-F10 trans
&trans     &kp F1     &kp F2     &kp F3     &kp F4     &kp F5                                                     &kp F6     &kp F7     &kp F8     &kp F9     &kp F10    &trans
// A行: trans F11 F12 ...
&trans     &kp F11    &kp F12    &none      &none      &none                                                      &none      &none      &none      &none      &none      &trans
// Z行: trans throughout
&trans     &none      &none      &none      &none      &none      &trans                     &trans             &none      &none      &none      &none      &none      &trans
// 親指row: trans
&none      &none      &none      &none      &trans     &trans     &trans                     &trans             &trans     &trans     &none      &none      &none      &none
            >;
        };

        // ========== Layer 3: アプリ切替 + BT/OUT制御 (MO(1)+MO(2)) ==========
        layer_3 {
            bindings = <
// Q行: NO M1 M2 M3 M4 M5 | M6 NO NO NO M0 NO  (アプリ切替マクロ)
&none         &m_app1       &m_app2       &m_app3       &m_app4       &m_app5                                                                  &m_app6       &none         &none         &none         &m_app0       &none
// A行: BT_CLR OUT_USB OUT_BLE OUT_TOG BT_NXT BT_PRV | BT_SEL0 BT_SEL1 BT_SEL2 BT_SEL3 BT_SEL4 NO
&bt BT_CLR    &out OUT_USB  &out OUT_BLE  &out OUT_TOG  &bt BT_NXT    &bt BT_PRV                                                               &bt BT_SEL 0  &bt BT_SEL 1  &bt BT_SEL 2  &bt BT_SEL 3  &bt BT_SEL 4  &none
// Z行: 全 none
&none         &none         &none         &none         &none         &none         &none                                       &none           &none         &none         &none         &none         &none         &none
// 親指row: 全 none
&none         &none         &none         &none         &none         &none         &none                                       &none           &none         &none         &none         &none         &none         &none
            >;
        };
    };
};
